# ============ 一键 Docker 部署（复制为 .env 后填写） ============
# cp .env.example .env

# DeepSeek（必填，否则对话无法调用模型）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Embedding 配置（可选，用于 Schema 混合检索；默认复用 DeepSeek 配置）
# 如需使用 OpenAI Embedding，请配置以下变量：
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small

# 后端日志级别（docker compose 传入后端容器）
LOG_LEVEL=INFO

# 浏览器访问前端的宿主机端口（http://localhost:<HTTP_PORT>）
HTTP_PORT=8080

# 是否把后端 API 直接暴露在宿主机（便于打开 /docs；前端仍通过 Nginx 同域访问 /api）
BACKEND_PUBLISH_PORT=8000

# PostgreSQL（可选，默认使用 SQLite；如需 PG 请取消注释并配置）
# POSTGRES_USER=chatbi
# POSTGRES_PASSWORD=chatbi
# POSTGRES_DB=chatbi
# APP_DB_URL=postgresql+psycopg2://chatbi:chatbi@postgres:5432/chatbi
